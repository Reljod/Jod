#!/usr/bin/env sh
# Deterministic commit-message gate.
#
# Enforces:  <type>(optional-scope)!: <TICKET> <subject>
#   e.g.     feat: ENG-123 add retry to the sync worker
#            fix(api)!: PLATFORM-7 drop the v1 orders route
#            chore: bump ruff to 0.6         (exempt type, no ticket needed)
#
# Same message in -> same pass/fail out. No network, no clock, no judgment.
# Rules come from ./commit-convention.conf so this script never needs edits.
set -eu

MSG_FILE="${1:?commit-msg hook expects the message file path as \$1}"
HOOK_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
CONF="$HOOK_DIR/commit-convention.conf"

# ---- defaults (overridden by conf if present) -----------------------------
ALLOWED_TYPES="feat|fix|bug|chore|docs|refactor|test|perf|ci|build|style|revert"
TICKET_REGEX="[A-Z][A-Z0-9]+-[0-9]+"
TICKET_EXEMPT_TYPES="chore|docs|style|ci"
MAX_SUBJECT_LENGTH=72
# shellcheck disable=SC1090
[ -f "$CONF" ] && . "$CONF"

RED=''; YEL=''; RST=''
if [ -t 2 ]; then RED="$(printf '\033[31m')"; YEL="$(printf '\033[33m')"; RST="$(printf '\033[0m')"; fi

fail() {
  printf '%s\n' "${RED}✗ commit rejected: $1${RST}" >&2
  printf '%s\n' "" >&2
  printf '%s\n' "  Required format: ${YEL}<type>: <TICKET> <subject>${RST}" >&2
  printf '%s\n' "  Types:   $ALLOWED_TYPES" >&2
  printf '%s\n' "  Ticket:  matches /$TICKET_REGEX/  (e.g. ENG-123), required unless type is one of: $TICKET_EXEMPT_TYPES" >&2
  printf '%s\n' "" >&2
  printf '%s\n' "  Good:  feat: ENG-123 add retry to the sync worker" >&2
  printf '%s\n' "  Good:  chore: bump ruff to 0.6" >&2
  printf '%s\n' "  Bad:   update stuff        (no type, no ticket)" >&2
  printf '%s\n' "" >&2
  printf '%s\n' "  This is a local courtesy check. --no-verify bypasses it; CI does not." >&2
  exit 1
}

# First line that is neither a comment (#...) nor blank is the subject.
SUBJECT="$(grep -vE '^[[:space:]]*#' "$MSG_FILE" | grep -vE '^[[:space:]]*$' | head -n1 || true)"

# Let git's own auto-generated messages through untouched.
case "$SUBJECT" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*|"amend! "*) exit 0 ;;
esac

[ -n "$SUBJECT" ] || fail "empty commit message"

# Structural check: type, optional (scope), optional !, ": ", then a rest.
if ! printf '%s' "$SUBJECT" | grep -qE "^($ALLOWED_TYPES)(\([a-z0-9._/-]+\))?!?: .+"; then
  fail "\"$SUBJECT\" does not match <type>: <subject>"
fi

# Extract the leading type (letters up to the first ( ! or :) and the rest.
TYPE="$(printf '%s' "$SUBJECT" | sed -E 's/^([a-zA-Z]+).*/\1/')"
REST="$(printf '%s' "$SUBJECT" | sed -E 's/^[^:]*:[[:space:]]*//')"

# Ticket requirement, unless the type is exempt or SKIP_TICKET is set.
if [ "${SKIP_TICKET:-0}" != "1" ] && ! printf '%s' "$TYPE" | grep -qE "^($TICKET_EXEMPT_TYPES)$"; then
  if ! printf '%s' "$REST" | grep -qE "^$TICKET_REGEX .+"; then
    fail "\"$SUBJECT\" is missing a ticket key (expected /$TICKET_REGEX/ right after the colon)"
  fi
fi

# Length ceiling.
if [ "${MAX_SUBJECT_LENGTH:-0}" -gt 0 ]; then
  LEN="$(printf '%s' "$SUBJECT" | wc -c | tr -d ' ')"
  if [ "$LEN" -gt "$MAX_SUBJECT_LENGTH" ]; then
    fail "subject is $LEN chars; keep it <= $MAX_SUBJECT_LENGTH"
  fi
fi

exit 0
